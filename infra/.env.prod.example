# Copy this to infra/.env.prod and fill in real values
# Never commit .env.prod to git

SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars

# Uses the VM's existing PostgreSQL 17
DATABASE_URL=postgresql+asyncpg://lifeplan_user:YOUR_DB_PASSWORD@127.0.0.1:5432/lifeplan_db
DATABASE_URL_SYNC=postgresql+psycopg2://lifeplan_user:YOUR_DB_PASSWORD@127.0.0.1:5432/lifeplan_db

MONGODB_URI=
GOOGLE_APPLICATION_CREDENTIALS=/app/adc.json
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must point to backend callback endpoint:
# http://<YOUR_VM_IP>:8001/api/v1/auth/google/callback
GOOGLE_REDIRECT_URI=
# Deep-link used by Android app after OAuth callback
GOOGLE_NATIVE_REDIRECT_URI=com.antigravity.lifeplan://auth

GCP_PROJECT_ID=project-85808d2c-7ca5-4412-a80
GCP_REGION=europe-west6
VERTEX_AI_MODEL=gemini-2.5-flash
VERTEX_AI_MODEL_FALLBACKS=gemini-2.0-flash-001
VERTEX_AI_FALLBACK_REGIONS=us-central1

# Optional secondary LLM fallback when Vertex fails all model/region candidates.
ENABLE_GROQ_FALLBACK=true
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=moonshotai/kimi-k2-instruct-0905
GROQ_MODEL_FALLBACKS=

# APK connects to this — include port 8001
ALLOWED_ORIGINS=http://34.17.126.204:8001,capacitor://localhost,http://localhost,http://localhost:5173

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
