# LifePlan Production Environment
# Copy to infra/.env.prod and fill in all values marked with <>
# Run: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=LifePlan
DEBUG=false

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<replace-with-64-char-hex>

# ─── PostgreSQL (matches the db service in docker-compose.prod.yml) ───────────
# POSTGRES_PASSWORD is used by both the db container and the DATABASE_URL override
POSTGRES_PASSWORD=<your-secure-db-password>

# These are overridden in docker-compose.prod.yml with Docker hostnames.
# Keep them here as fallback / for alembic run outside Docker.
DATABASE_URL=postgresql+asyncpg://lifeplan_user:<your-secure-db-password>@127.0.0.1:5432/lifeplan_db
DATABASE_URL_SYNC=postgresql+psycopg2://lifeplan_user:<your-secure-db-password>@127.0.0.1:5432/lifeplan_db

# ─── MongoDB (overridden in docker-compose.prod.yml with Docker hostname) ─────
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB_NAME=lifeplan

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Web frontend hits port 80 (nginx), Android APK hits backend directly on 8002
ALLOWED_ORIGINS=http://<YOUR_VM_EXTERNAL_IP>,http://<YOUR_VM_EXTERNAL_IP>:8002,capacitor://localhost,http://localhost,http://localhost:5173

# ─── Auth tokens ──────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Google Cloud / Vertex AI ─────────────────────────────────────────────────
GCP_PROJECT_ID=iri-gemini
# europe-west12 (Turin) does NOT have Gemini — use europe-west1 or us-central1
GCP_REGION=us-central1
VERTEX_AI_MODEL=gemini-2.5-flash
VERTEX_AI_MODEL_FALLBACKS=gemini-2.0-flash-001,gemini-1.5-flash
VERTEX_AI_FALLBACK_REGIONS=europe-west1
# ADC credentials are mounted at /app/adc.json by docker-compose.prod.yml
GOOGLE_APPLICATION_CREDENTIALS=/app/adc.json

# ─── Groq fallback (optional — keeps chat working if Vertex is down) ──────────
ENABLE_GROQ_FALLBACK=true
GROQ_API_KEY=<your-groq-api-key-or-leave-blank>
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=moonshotai/kimi-k2-instruct-0905

# ─── Google OAuth (for Login with Google + Calendar) ─────────────────────────
GOOGLE_CLIENT_ID=<your-oauth-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-oauth-client-secret>
# Backend callback — must match what's in GCP Console OAuth credentials
GOOGLE_REDIRECT_URI=http://<YOUR_VM_EXTERNAL_IP>:8002/api/v1/auth/google/callback
# Android APK deep-link after OAuth
GOOGLE_NATIVE_REDIRECT_URI=com.antigravity.lifeplan://auth

# ─── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-004
