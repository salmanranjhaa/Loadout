loadedout.online {
    # Proxy API requests to the FastAPI backend
    handle /api/* {
        reverse_proxy backend:8000
    }

    # Proxy MCP server, stripping the /mcp prefix before forwarding
    handle_path /mcp/* {
        reverse_proxy mcp:8003 {
            # I disable response buffering so SSE events stream through immediately
            flush_interval -1
        }
    }

    # Serve the React SPA (fallback)
    handle {
        root * /usr/share/caddy
        try_files {path} /index.html
        file_server
    }
}

