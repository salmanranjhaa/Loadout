APP_NAME=LifePlan
DEBUG=false

# Database (Cloud SQL)
DATABASE_URL=postgresql+asyncpg://lifeplan_user:YOUR_PASSWORD@/lifeplan_db?host=/cloudsql/YOUR_PROJECT:europe-west6:lifeplan-db
DATABASE_URL_SYNC=postgresql+psycopg2://lifeplan_user:YOUR_PASSWORD@/lifeplan_db?host=/cloudsql/YOUR_PROJECT:europe-west6:lifeplan-db

# For local dev
# DATABASE_URL=postgresql+asyncpg://lifeplan_user:changeme@localhost:5432/lifeplan_db
# DATABASE_URL_SYNC=postgresql+psycopg2://lifeplan_user:changeme@localhost:5432/lifeplan_db

# Auth
SECRET_KEY=generate-a-long-random-string-here

# Google Cloud
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west6
VERTEX_AI_MODEL=gemini-1.5-flash
EMBEDDING_MODEL=text-embedding-004
